{
  "schema_version": 1,
  "claims": [
    {
      "id": "UC-FIXED-OUTPUT-PRESERVED",
      "predicate": "output_not_overwritten",
      "description": "A fixed-role cell with occupied output must not overwrite that output during a blocked transition.",
      "examples": [
        {
          "name": "blocked output preserved",
          "expected": true,
          "before": {
            "role": "wire",
            "memory": "right",
            "input": [1, 0, 0],
            "output": [0, "_", "_"]
          },
          "result": {
            "status": "blocked-output",
            "cell": {
              "role": "wire",
              "memory": "right",
              "input": [1, 0, 0],
              "output": [0, "_", "_"]
            }
          }
        },
        {
          "name": "blocked output changed",
          "expected": false,
          "before": {
            "role": "wire",
            "memory": "right",
            "input": [1, 0, 0],
            "output": [0, "_", "_"]
          },
          "result": {
            "status": "blocked-output",
            "cell": {
              "role": "wire",
              "memory": "right",
              "input": [1, 0, 0],
              "output": [1, 1, 1]
            }
          }
        }
      ]
    },
    {
