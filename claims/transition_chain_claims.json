{
  "schema_version": 1,
  "claims": [
    {
      "id": "UC-CHAIN-NEIGHBOR-DELIVERY-RECIPIENT-CONSUMED",
      "predicate": "neighbor_delivery_consumed_by_recipient",
      "description": "A neighbor delivery chain that produces an init-family command token can install that token as recipient upstream state and consume it through recipient init-family command logic.",
      "examples": [
        {
          "name": "neighbor b proc left delivery consumed by empty recipient",
          "expected": true,
          "sender": {
            "role": "stem",
            "memory": "right",
            "input": [1, 0, 0],
            "control": [1, 0, 0],
            "buffer": [1, 0, 1, 0]
          },
          "recipient": {
            "role": "wire",
            "memory": "right"
          }
        },
        {
          "name": "self write buffer completion is not neighbor delivery",
          "expected": false,
          "sender": {
            "role": "stem",
            "memory": "right",
            "input": [0, 1, 0],
            "control": [0, 1, 0],
            "buffer": [0, 0, 1, 1]
          },
          "recipient": {
            "role": "wire",
            "memory": "right"
          }
        },
        {
          "name": "recipient pending upstream blocks delivered command",
          "expected": false,
          "sender": {
            "role": "stem",
            "memory": "right",
            "input": [1, 0, 0],
            "control": [1, 0, 0],
            "buffer": [1, 0, 1, 0]
          },
          "recipient": {
            "role": "wire",
            "memory": "right",
            "upstream": [0, "_", "_"]
          }
        },
        {
          "name": "neighbor c write buffer delivery remains unconsumed",
          "expected": false,
          "sender": {
            "role": "stem",
            "memory": "right",
            "input": [0, 1, 0],
            "control": [0, 1, 0],
            "buffer": [1, 1, 1, 1]
          },
          "recipient": {
            "role": "wire",
            "memory": "right"
          }
        }
      ]
    }
  ]
}
